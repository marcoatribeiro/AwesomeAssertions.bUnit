<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <Nullable>enable</Nullable>

        <Description>Extension methods that provide awesome assertions on top of BUnit.</Description>
		<AssemblyTitle>AwesomeAssertions - BUnit</AssemblyTitle>
		<Authors>Marco Ribeiro</Authors>
		<Company />
		<PackageId>AwesomeAssertions.BUnit</PackageId>
		<PackageVersion>0.1.0</PackageVersion>
		<Version>0.1.0</Version>
        <PackageTags>Blazor;BUnit;AwesomeAssertions</PackageTags>
		<PackageLicenseExpression>MIT OR Apache-2.0</PackageLicenseExpression>
        <PackageProjectUrl>https://github.com/marcoatribeiro/AwesomeAssertions.bUnit</PackageProjectUrl>
        <RepositoryType>git</RepositoryType>
        <RepositoryUrl>https://github.com/marcoatribeiro/AwesomeAssertions.bUnit</RepositoryUrl>
        <Summary>Test Blazor Components with AwesomeAssertions</Summary>
    </PropertyGroup>

    <ItemGroup>
      <PackageReference Include="AngleSharp" Version="1.4.0" />
      <PackageReference Include="bunit" Version="2.0.66" />
      <PackageReference Include="AwesomeAssertions" Version="9.4.0" />
    </ItemGroup>

</Project>
